{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@cli/*": ["./src/cli/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/cli/**/*.ts", "src/core/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
